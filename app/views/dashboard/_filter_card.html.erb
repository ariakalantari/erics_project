<section class="rounded-xl border border-zinc-200 bg-white shadow-lg p-5"
         data-controller="filters">
  <div class="flex items-center justify-between mb-3">
    <h2 class="text-[11px] uppercase tracking-wider text-zinc-500 font-medium">Filters</h2>
    <button type="button"
            data-action="filters#reset"
            class="text-[11px] text-zinc-500 hover:text-zinc-900 underline-offset-2 hover:underline">Reset</button>
  </div>

  <div class="space-y-2.5">
    <% [
      { key: "status:available",      label: "Available",      icon: "circle-check", color: "text-emerald-500" },
      { key: "status:occupied",       label: "Occupied",       icon: "circle",       color: "text-zinc-400"    },
      { key: "status:reserved",       label: "Reserved",       icon: "clock",        color: "text-amber-500"   },
      { key: "status:out_of_service", label: "Out of service", icon: "ban",          color: "text-red-500"     },
      { key: "type:ev_charging",      label: "EV chargers only", icon: "zap",        color: "text-blue-500"    },
      { key: "type:accessible",       label: "Accessible only",  icon: "accessibility", color: "text-zinc-700" }
    ].each do |opt| %>
      <label class="flex items-center justify-between text-sm cursor-pointer group py-1">
        <span class="flex items-center gap-2.5 text-zinc-700 group-hover:text-zinc-900">
          <i data-lucide="<%= opt[:icon] %>" class="w-3.5 h-3.5 <%= opt[:color] %>"></i>
          <%= opt[:label] %>
        </span>
        <span class="relative">
          <input type="checkbox"
                 class="peer sr-only"
                 data-filters-target="checkbox"
                 data-filter-key="<%= opt[:key] %>"
                 <%= "checked" if opt[:key].start_with?("status:") %>
                 data-action="change->filters#emit">
          <span class="block w-9 h-5 rounded-full bg-zinc-200 peer-checked:bg-emerald-500 transition-colors"></span>
          <span class="absolute top-0.5 left-0.5 w-4 h-4 rounded-full bg-white shadow transition-transform peer-checked:translate-x-4"></span>
        </span>
      </label>
    <% end %>
  </div>
</section>
