<% spot      = activity.parking_spot %>
<% to_color  = ParkingSpot::STATUS_COLORS[activity.to_status] %>
<li id="activity_<%= activity.id %>"
    class="flex items-start gap-3 group activity-flash cursor-pointer rounded-lg px-2 py-2 hover:bg-zinc-50 transition-colors"
    data-controller="activity-entry"
    data-action="click->activity-entry#flyTo"
    data-activity-entry-lat-value="<%= spot.lat %>"
    data-activity-entry-lng-value="<%= spot.lng %>"
    data-activity-entry-url-value="<%= parking_spot_path(spot) %>">
  <div class="shrink-0 w-8 h-8 rounded-md bg-zinc-100 flex items-center justify-center"
       style="color: <%= to_color %>">
    <i data-lucide="<%= status_icon(activity.to_status) %>" class="w-4 h-4"></i>
  </div>
  <div class="flex-1 min-w-0">
    <div class="text-sm text-zinc-900">
      <span class="font-medium"><%= spot.identifier %></span>
      <span class="text-zinc-500"> marked </span>
      <span class="font-medium" style="color: <%= to_color %>"><%= activity.to_status.tr("_", " ") %></span>
    </div>
    <div class="text-[11px] text-zinc-400 mt-0.5"><%= spot.parking_area.name %></div>
  </div>
  <div class="text-[11px] text-zinc-400 tabular-nums shrink-0"><%= time_ago_in_words(activity.created_at) %> ago</div>
</li>
