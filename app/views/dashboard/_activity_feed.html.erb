<%= turbo_stream_from "activity" %>

<div class="rounded-xl border border-zinc-200 bg-white shadow-lg overflow-hidden"
     data-controller="disclosure">
  <button type="button"
          data-action="disclosure#toggle"
          class="w-full flex items-center justify-between px-5 py-3.5 hover:bg-zinc-50 transition-colors">
    <span class="text-sm font-medium text-zinc-900">Recent activity</span>
    <i data-lucide="chevron-down" data-disclosure-target="chevron" class="w-4 h-4 text-zinc-400"></i>
  </button>

  <div data-disclosure-target="panel" hidden class="border-t border-zinc-100">
    <ul id="activity_feed" class="space-y-1 overflow-y-auto p-3" style="max-height: 240px;">
      <% if activities.empty? %>
        <li id="activity_empty" class="text-xs text-zinc-400 italic text-center py-6 px-2">
          No activity yet — click a spot on the map and change its status to see entries appear here.
        </li>
      <% end %>
      <% activities.each do |activity| %>
        <%= render "activity_entry", activity: activity %>
      <% end %>
    </ul>
  </div>
</div>
