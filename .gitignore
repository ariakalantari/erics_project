# See https://help.github.com/articles/ignoring-files for more about ignoring files.

# Ignore bundler config.
/.bundle

# Ignore the default SQLite databases (dev/test).
/storage/*
!/storage/.keep
/db/*.sqlite3
/db/*.sqlite3-journal
/db/*.sqlite3-*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/.keep

# Ignore uploaded files in development and any SQLite databases.
/tmp/storage/*
!/tmp/storage/.keep

# Ignore precompiled and built assets.
/public/assets
/app/assets/builds/*
!/app/assets/builds/.keep

# Ignore master key for decrypting Rails credentials.
/config/master.key
/config/credentials/*.key

# Ignore .env files.
/.env*
!/.env.example

# Editor / OS junk.
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Local Claude settings (per-machine).
/.claude/

# Node (in case anyone adds it later).
/node_modules/
